@article{gao_review_2022,
	title = {A review of distributed statistical inference},
	volume = {6},
	issn = {2475-4269},
	url = {https://doi.org/10.1080/24754269.2021.1974158},
	doi = {10.1080/24754269.2021.1974158},
	abstract = {The rapid emergence of massive datasets in various fields poses a serious challenge to traditional statistical methods. Meanwhile, it provides opportunities for researchers to develop novel algorithms. Inspired by the idea of divide-and-conquer, various distributed frameworks for statistical estimation and inference have been proposed. They were developed to deal with large-scale statistical optimization problems. This paper aims to provide a comprehensive review for related literature. It includes parametric models, nonparametric models, and other frequently used models. Their key ideas and theoretical properties are summarized. The trade-off between communication cost and estimate precision together with other concerns is discussed.},
	number = {2},
	urldate = {2025-08-11},
	journal = {Statistical Theory and Related Fields},
	author = {Gao, Yuan and Liu, Weidong and Wang, Hansheng and Wang, Xiaozhou and Yan, Yibo and Zhang, Riquan},
	month = may,
	year = {2022},
	note = {Publisher: Taylor \& Francis
\_eprint: https://doi.org/10.1080/24754269.2021.1974158},
	keywords = {bootstrap, communication-efficiency, Distributed computing, divide-and-conquer, feature screening, nonparametric estimation, principal component analysis, shrinkage methods},
	pages = {89--99},
	file = {Full Text PDF:/home/pedege/snap/zotero-snap/common/Zotero/storage/F7K3X85M/Gao et al. - 2022 - A review of distributed statistical inference.pdf:application/pdf},
}

@article{pazira_bayesian_2025,
	title = {Bayesian federated inference for survival models},
	volume = {0},
	issn = {0266-4763},
	url = {https://doi.org/10.1080/02664763.2025.2511932},
	doi = {10.1080/02664763.2025.2511932},
	abstract = {To accurately estimate the parameters in a prediction model for survival data, sufficient events need to be observed compared to the number of model parameters. In practice, this is often a problem. Merging data sets from different medical centers may help, but this is not always possible due to strict privacy legislation and logistic difficulties. Recently, the Bayesian Federated Inference (BFI) strategy for generalized linear models was proposed. With this strategy, the statistical analyzes are performed in the local centers where the data were collected (or stored), and only the inference results are combined to a single estimated model; merging data is not necessary. The BFI methodology aims to compute from the separate inference results in the local centers what would have been obtained if the analysis had been based on the merged data sets. In the present paper, we generalize the BFI methodology as initially developed for generalized linear models to survival models. Simulation studies and real data analyzes show excellent performance; that is, the results obtained with the BFI methodology are very similar to the results obtained by analyzing the merged data. An R package for doing the analyzes is available.},
	number = {0},
	urldate = {2025-08-21},
	journal = {Journal of Applied Statistics},
	author = {Pazira, Hassan and Massa, Emanuele and Weijers, Jetty A.M. and Coolen, Anthony C.C. and Jonker, Marianne A.},
	month = jun,
	year = {2025},
	note = {Publisher: Taylor \& Francis
\_eprint: https://doi.org/10.1080/02664763.2025.2511932},
	keywords = {federated learning, distributed inference, one-shot algorithm, 62F07, 62F15, 62N02, 62P10, 91G70, Decentralized data, rare cancer},
	pages = {1--21},
	file = {Full Text PDF:/home/pedege/snap/zotero-snap/common/Zotero/storage/EYNZPQ2P/Pazira et al. - Bayesian federated inference for survival models.pdf:application/pdf},
}

